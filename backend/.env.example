DATABASE_URL="postgresql://usuario:password@host:5432/uniride?schema=public"
JWT_SECRET="cambia_esto_por_un_secreto_seguro_min_32_chars"
JWT_EXPIRES_IN="7d"
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# CORS — URL del frontend en Vercel (sin slash al final). Coma-separado para varios.
# Ejemplo: https://uniride.vercel.app,http://localhost:4200
ALLOWED_ORIGINS="https://tu-app.vercel.app"

# reCAPTCHA (opcional en dev, REQUERIDO en producción)
RECAPTCHA_SECRET=""
RECAPTCHA_MIN_SCORE=0.5
